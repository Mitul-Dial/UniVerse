<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.universe.controllers.DashboardController"
           fx:id="dashboardStackRoot">
<BorderPane styleClass="dashboard-root" fx:id="dashboardRoot">

    <top>
        <VBox>
            <!-- ═══ TOP BAR ═══ -->
            <HBox styleClass="dash-topbar" alignment="CENTER_LEFT" spacing="16">
                <padding><Insets top="0" right="20" bottom="0" left="20"/></padding>

                <HBox styleClass="dash-logo" alignment="CENTER_LEFT" spacing="8" minWidth="180">
                    <Label text="UniVerse" styleClass="dash-logo-text"/>
                </HBox>

                <!-- Search bar removed as per request -->

                <Region HBox.hgrow="ALWAYS"/>

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <!-- Bell icon removed as per request -->
                    <StackPane fx:id="userAvatarBtn" styleClass="dash-avatar" maxWidth="36" maxHeight="36" minWidth="36" minHeight="36">
                        <Label fx:id="userAvatarText" text="UA" styleClass="dash-avatar-text"/>
                    </StackPane>
                    <Button text="← Back to site" styleClass="dash-close-btn" onAction="#handleBackToSite"/>
                </HBox>
            </HBox>

            <!-- ═══ TAB BAR ═══ -->
            <HBox styleClass="dash-tabs" alignment="CENTER" spacing="0" fx:id="tabBar">
                <Button text="Events" styleClass="dash-tab,dash-tab-events" fx:id="tabEvents"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity" maxHeight="Infinity">
                    <graphic><Label text="24" styleClass="dash-tab-badge"/></graphic>
                </Button>
                <Button text="Societies" styleClass="dash-tab,dash-tab-societies" fx:id="tabSocieties"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity" maxHeight="Infinity"/>
                <Button text="Announcements" styleClass="dash-tab,dash-tab-announcements" fx:id="tabAnnouncements"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity" maxHeight="Infinity"/>
                <Button text="Sponsors" styleClass="dash-tab,dash-tab-sponsors" fx:id="tabSponsors"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity" maxHeight="Infinity"/>
                <Button text="Admin" styleClass="dash-tab,dash-tab-admin" fx:id="tabAdmin"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity" maxHeight="Infinity"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane fx:id="contentStack">

            <!-- ═══ EVENTS PANEL ═══ -->
            <StackPane fx:id="panelEventsWrapper">
                <Pane fx:id="blobPaneEvents" mouseTransparent="true"/>
                <HBox fx:id="panelEvents" style="-fx-background-color: linear-gradient(to bottom right, rgba(232,240,254,0.55), rgba(255,255,255,0));">
                    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="dash-feed-scroll" HBox.hgrow="ALWAYS">
                        <VBox styleClass="dash-feed" spacing="0" fx:id="eventsFeed">
                            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

                            <HBox styleClass="welcome-banner" alignment="CENTER_LEFT" spacing="0" fx:id="welcomeBanner"
                                  style="-fx-background-color: linear-gradient(to bottom right, #1a73e8, #1557b0);"
                                  opacity="0">
                                <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>
                                <VBox HBox.hgrow="ALWAYS">
                                    <Label fx:id="welcomeTitleLabel" text="Good afternoon, User 👋" styleClass="welcome-title"/>
                                    <Label fx:id="welcomeSubtitleLabel" text="Welcome to UniVerse" styleClass="welcome-subtitle"/>
                                </VBox>
                                <HBox fx:id="welcomeActionsBox" alignment="CENTER_RIGHT" spacing="10">
                                </HBox>
                            </HBox>

                            <GridPane styleClass="stats-row-dash" hgap="14" vgap="0" fx:id="dashStatsRow">
                                <VBox.margin><Insets top="24" bottom="24"/></VBox.margin>
                                <columnConstraints>
                                    <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                                    <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                                    <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                                    <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                                </columnConstraints>

                                <VBox styleClass="dash-stat" GridPane.columnIndex="0" fx:id="dashStat0" opacity="0" translateY="20">
                                    <padding><Insets top="16" right="18" bottom="16" left="18"/></padding>
                                    <HBox alignment="CENTER_LEFT" spacing="6">
                                        <Circle radius="4" fill="#1a73e8"/>
                                        <Label text="Total Events" styleClass="dash-stat-label-text"/>
                                    </HBox>
                                    <Label fx:id="statVal0" text="—" styleClass="dash-stat-val"/>
                                    <Label fx:id="statDesc0" text="Loading..." styleClass="dash-stat-change-green"/>
                                </VBox>
                                <VBox styleClass="dash-stat" GridPane.columnIndex="1" fx:id="dashStat1" opacity="0" translateY="20">
                                    <padding><Insets top="16" right="18" bottom="16" left="18"/></padding>
                                    <HBox alignment="CENTER_LEFT" spacing="6">
                                        <Circle radius="4" fill="#34a853"/>
                                        <Label text="Registered" styleClass="dash-stat-label-text"/>
                                    </HBox>
                                    <Label fx:id="statVal1" text="—" styleClass="dash-stat-val"/>
                                    <Label fx:id="statDesc1" text="Loading..." styleClass="dash-stat-change-yellow"/>
                                </VBox>
                                <VBox styleClass="dash-stat" GridPane.columnIndex="2" fx:id="dashStat2" opacity="0" translateY="20">
                                    <padding><Insets top="16" right="18" bottom="16" left="18"/></padding>
                                    <HBox alignment="CENTER_LEFT" spacing="6">
                                        <Circle radius="4" fill="#ea4335"/>
                                        <Label text="Societies" styleClass="dash-stat-label-text"/>
                                    </HBox>
                                    <Label fx:id="statVal2" text="—" styleClass="dash-stat-val"/>
                                    <Label fx:id="statDesc2" text="Loading..." styleClass="dash-stat-change-green"/>
                                </VBox>
                                <VBox styleClass="dash-stat" GridPane.columnIndex="3" fx:id="dashStat3" opacity="0" translateY="20">
                                    <padding><Insets top="16" right="18" bottom="16" left="18"/></padding>
                                    <HBox alignment="CENTER_LEFT" spacing="6">
                                        <Circle radius="4" fill="#fbbc04"/>
                                        <Label text="Sponsors" styleClass="dash-stat-label-text"/>
                                    </HBox>
                                    <Label fx:id="statVal3" text="—" styleClass="dash-stat-val"/>
                                    <Label fx:id="statDesc3" text="Loading..." styleClass="dash-stat-change-green"/>
                                </VBox>
                            </GridPane>

                            <Label text="UPCOMING EVENTS" styleClass="feed-section-title">
                                <VBox.margin><Insets bottom="12"/></VBox.margin>
                            </Label>

                            <VBox fx:id="eventFeedList" spacing="10"/>
                        </VBox>
                    </ScrollPane>

                    <VBox styleClass="dash-sidebar" minWidth="280" maxWidth="280" prefWidth="280">
                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                        <VBox styleClass="mini-cal" spacing="12">
                            <HBox alignment="CENTER_LEFT" spacing="0">
                                <Label fx:id="calMonthLabel" text="April 2026" styleClass="mini-cal-title"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <HBox spacing="4">
                                    <Button text="‹" styleClass="mini-cal-btn" onAction="#handleCalPrev"/>
                                    <Button text="›" styleClass="mini-cal-btn" onAction="#handleCalNext"/>
                                </HBox>
                            </HBox>
                            <GridPane fx:id="calGrid" styleClass="cal-grid" hgap="2" vgap="2"/>
                        </VBox>

                        <VBox fx:id="dayEventInfo" styleClass="day-event-box">
                            <VBox.margin><Insets top="16"/></VBox.margin>
                        </VBox>

                        <VBox fx:id="studentRegistrationsBox" styleClass="day-event-box" managed="false" visible="false">
                            <VBox.margin><Insets top="16"/></VBox.margin>
                        </VBox>
                    </VBox>
                </HBox>
            </StackPane>

            <!-- ═══ SOCIETIES PANEL ═══ -->
            <StackPane fx:id="panelSocietiesWrapper" visible="false" managed="false">
                <Pane fx:id="blobPaneSocieties" mouseTransparent="true"/>
                <ScrollPane fx:id="panelSocieties" fitToWidth="true" hbarPolicy="NEVER" styleClass="panel-scroll"
                            style="-fx-background-color: transparent; -fx-background: transparent;">
                    <VBox styleClass="societies-panel" spacing="0"
                          style="-fx-background-color: linear-gradient(to bottom right, rgba(230,244,234,0.55), rgba(255,255,255,0));">
                        <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                        <Label fx:id="societiesPanelHeading" text="All Societies" styleClass="panel-heading"/>
                        <Label fx:id="societiesPanelSubheading" text="Loading societies..." styleClass="panel-subheading">
                            <VBox.margin><Insets bottom="20"/></VBox.margin>
                        </Label>
                        <GridPane fx:id="societiesGrid" styleClass="societies-grid" hgap="16" vgap="16">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="33.3"/>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="33.3"/>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="33.3"/>
                            </columnConstraints>
                        </GridPane>
                    </VBox>
                </ScrollPane>
            </StackPane>

            <!-- ═══ ANNOUNCEMENTS PANEL ═══ -->
            <StackPane fx:id="panelAnnouncementsWrapper" visible="false" managed="false">
                <Pane fx:id="blobPaneAnnouncements" mouseTransparent="true"/>
                <ScrollPane fx:id="panelAnnouncements" fitToWidth="true" hbarPolicy="NEVER" styleClass="panel-scroll"
                            style="-fx-background-color: transparent; -fx-background: transparent;">
                    <VBox styleClass="announce-panel" spacing="0"
                          style="-fx-background-color: linear-gradient(to bottom right, rgba(255,248,225,0.55), rgba(255,255,255,0));">
                        <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                        <Label text="Announcements" styleClass="panel-heading"/>
                        <Label text="All updates from societies and university admin" styleClass="panel-subheading">
                            <VBox.margin><Insets bottom="20"/></VBox.margin>
                        </Label>
                        <VBox fx:id="announcementsList" spacing="10"/>
                    </VBox>
                </ScrollPane>
            </StackPane>

            <!-- ═══ SPONSORS PANEL ═══ -->
            <StackPane fx:id="panelSponsorsWrapper" visible="false" managed="false">
                <Pane fx:id="blobPaneSponsors" mouseTransparent="true"/>
                <ScrollPane fx:id="panelSponsors" fitToWidth="true" hbarPolicy="NEVER" styleClass="panel-scroll"
                            style="-fx-background-color: transparent; -fx-background: transparent;">
                    <VBox styleClass="sponsors-panel" spacing="0"
                          style="-fx-background-color: linear-gradient(to bottom right, rgba(243,229,245,0.50), rgba(255,255,255,0));">
                        <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                        <Label text="Sponsorship Opportunities" styleClass="panel-heading"/>
                        <Label text="Connect with societies and support upcoming events" styleClass="panel-subheading">
                            <VBox.margin><Insets bottom="20"/></VBox.margin>
                        </Label>
                        <GridPane fx:id="sponsorsGrid" hgap="16" vgap="16">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                            </columnConstraints>
                        </GridPane>
                    </VBox>
                </ScrollPane>
            </StackPane>

            <!-- ═══ ADMIN PANEL ═══ -->
            <StackPane fx:id="panelAdminWrapper" visible="false" managed="false">
                <Pane fx:id="blobPaneAdmin" mouseTransparent="true"/>
                <ScrollPane fx:id="panelAdmin" fitToWidth="true" hbarPolicy="NEVER" styleClass="panel-scroll"
                            style="-fx-background-color: transparent; -fx-background: transparent;">
                    <VBox styleClass="admin-panel" spacing="0"
                          style="-fx-background-color: linear-gradient(to bottom right, rgba(232,240,254,0.50), rgba(255,235,235,0.30));">
                        <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                        <Label text="Admin Control Panel" styleClass="panel-heading"/>
                        <Label text="Manage events, societies, and platform settings" styleClass="panel-subheading">
                            <VBox.margin><Insets bottom="20"/></VBox.margin>
                        </Label>
                        <GridPane fx:id="adminGrid" hgap="16" vgap="16">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                            </columnConstraints>
                        </GridPane>
                    </VBox>
                </ScrollPane>
            </StackPane>

        </StackPane>
    </center>
</BorderPane>
</StackPane>
